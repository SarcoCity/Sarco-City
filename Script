-- ==================== VISUALS (Fixed ESP) ====================
local visuals = {}  -- player → {highlight1, highlight2, ...}

local ChamsEnabled = false
local BoxESPEnabled = false
local ChamsFillTransparency = 0.5

local EnemyChamsColor = Color3.fromRGB(255, 0, 0)
local TeamChamsColor = Color3.fromRGB(0, 255, 0)
local EnemyBoxColor = Color3.fromRGB(255, 0, 0)

local function clearVisuals(player)
    if visuals[player] then
        for _, obj in pairs(visuals[player]) do
            if obj and obj.Parent then
                obj:Destroy()
            end
        end
        visuals[player] = nil
    end
end

local function updateVisualsForPlayer(player)
    clearVisuals(player)
    
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    visuals[player] = {}

    if ChamsEnabled or BoxESPEnabled then
        local highlight = Instance.new("Highlight")
        highlight.Adornee = char
        highlight.FillTransparency = ChamsEnabled and ChamsFillTransparency or 1
        highlight.OutlineTransparency = BoxESPEnabled and 0 or 1
        highlight.FillColor = (player.Team == LocalPlayer.Team) and TeamChamsColor or EnemyChamsColor
        highlight.OutlineColor = (player.Team == LocalPlayer.Team) and TeamChamsColor or EnemyBoxColor
        highlight.Parent = char
        table.insert(visuals[player], highlight)
    end
end

local function setupVisuals()
    -- Current players
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            updateVisualsForPlayer(player)
        end
    end

    -- New players join
    Players.PlayerAdded:Connect(function(player)
        if player == LocalPlayer then return end
        
        -- When they spawn / respawn
        player.CharacterAdded:Connect(function()
            task.wait(0.4)  -- small delay so character is fully loaded
            updateVisualsForPlayer(player)
        end)
        
        -- When they die or leave
        player.CharacterRemoving:Connect(function()
            clearVisuals(player)
        end)
    end)

    -- When someone leaves the game
    Players.PlayerRemoving:Connect(function(player)
        clearVisuals(player)
    end)
end

-- ==================== OTHER FEATURES (unchanged) ====================
local function modifyGunStats()
	for _, obj in pairs(getgc(true)) do
		if type(obj) == "table" and rawget(obj, "Spread") then
			if NoSpreadEnabled then
				obj.Spread = 0
				obj.SpreadRedution = 1
				obj.VelocitySpreadDivisor = math.huge
				obj.MaxVelocitySpreadBonus = 0
			end
			if NoCameraShakeEnabled then
				if rawget(obj, "CameraShakingEnabled") then obj.CameraShakingEnabled = false end
				if rawget(obj, "Intensity") then obj.Intensity = 0 end
			end
			if (ZeroDelayEnabled or RapidFireEnabled or AllAutomaticEnabled) and rawget(obj, "FireRate") then
				obj.FireRate = AllAutomaticEnabled and AutomaticFireRate or 0
			end
			if (RapidFireEnabled or AllAutomaticEnabled) and rawget(obj, "BurstRate") then
				obj.BurstRate = 0
			end
			if AllAutomaticEnabled and rawget(obj, "Auto") then
				obj.Auto = true
			end
			if InfiniteAmmoEnabled then
				if rawget(obj, "ReloadTime") then obj.ReloadTime = 0 end
				if rawget(obj, "ReloadAnimationID") then obj.ReloadAnimationID = nil end
				if rawget(obj, "ReloadAnimationSpeed") then obj.ReloadAnimationSpeed = 0 end
				if rawget(obj, "AmmoPerClip") then obj.AmmoPerClip = 9999 end
			end
			if InstantHitEnabled and rawget(obj, "BulletSpeed") then
				obj.BulletSpeed = 9999
			end
		end
	end
end

-- Raycast Hook
local oldRayCast
for _, v in pairs(getgc(true)) do
	if type(v) == "function" and debug.getinfo(v).name == "RayCast" then
		oldRayCast = v
		break
	end
end
if oldRayCast then
	local function newRayCast(origin, direction, distance, ignore)
		if NoSpreadEnabled then
			local hitPosition = origin + direction.Unit * distance
			local fakeHit = Instance.new("Part")
			fakeHit.Transparency = 1
			fakeHit.CanCollide = false
			fakeHit.Anchored = true
			fakeHit.Position = hitPosition
			return fakeHit, hitPosition
		end
		return oldRayCast(origin, direction, distance, ignore)
	end
	hookfunction(oldRayCast, newRayCast)
end

-- Anti-Recoil
RunService.RenderStepped:Connect(function()
	if NoRecoilEnabled then
		if Camera:FindFirstChild("RecoilEffect") then Camera.RecoilEffect:Destroy() end
		local char = LocalPlayer.Character
		if char and char:FindFirstChild("Humanoid") then
			char.Humanoid.CameraOffset = Vector3.new(0, 0, 0)
		end
	end
end)

-- Fire Hook
local function findFireFunction()
	for _, v in pairs(getgc(true)) do
		if type(v) == "function" then
			local info = debug.getinfo(v)
			if info.source:find("GunScript") and info.name:find("Fire") then
				local function newFire(...)
					local args = {...}
					if NoSpreadEnabled and args[1] and type(args[1]) == "table" then
						args[1].Spread = 0
						args[1].CurrentSpread = 0
					end
					return v(unpack(args))
				end
				hookfunction(v, newFire)
				break
			end
		end
	end
end
findFireFunction()


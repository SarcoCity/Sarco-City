-- ==================== GUN MODS ====================
local function modifyGunStats()
    for _, obj in pairs(getgc(true)) do
        if type(obj) == "table" and rawget(obj, "Spread") then
            if NoSpreadEnabled then
                obj.Spread = 0
                obj.SpreadRedution = 1
                obj.VelocitySpreadDivisor = math.huge
                obj.MaxVelocitySpreadBonus = 0
            end
            if NoCameraShakeEnabled then
                if rawget(obj, "CameraShakingEnabled") then obj.CameraShakingEnabled = false end
                if rawget(obj, "Intensity") then obj.Intensity = 0 end
            end
            if (ZeroDelayEnabled or RapidFireEnabled or AllAutomaticEnabled) and rawget(obj, "FireRate") then
                obj.FireRate = AllAutomaticEnabled and AutomaticFireRate or 0
            end
            if (RapidFireEnabled or AllAutomaticEnabled) and rawget(obj, "BurstRate") then
                obj.BurstRate = 0
            end
            if AllAutomaticEnabled and rawget(obj, "Auto") then
                obj.Auto = true
            end
            if InfiniteAmmoEnabled then
                if rawget(obj, "ReloadTime") then obj.ReloadTime = 0 end
                if rawget(obj, "ReloadAnimationID") then obj.ReloadAnimationID = nil end
                if rawget(obj, "ReloadAnimationSpeed") then obj.ReloadAnimationSpeed = 0 end
                if rawget(obj, "AmmoPerClip") then obj.AmmoPerClip = 9999 end
            end
            if InstantHitEnabled and rawget(obj, "BulletSpeed") then
                obj.BulletSpeed = 9999
            end
            if InstantKillEnabled then
                if rawget(obj, "BaseDamage") then obj.BaseDamage = 9999 end
                if rawget(obj, "HeadshotDamageMultiplier") then obj.HeadshotDamageMultiplier = 9999 end
                if rawget(obj, "Piercing") then obj.Piercing = 9999 end
            end
        end
    end
end

-- Raycast Hook (unchanged)
local oldRayCast
for _, v in pairs(getgc(true)) do
    if type(v) == "function" and debug.getinfo(v).name == "RayCast" then
        oldRayCast = v
        break
    end
end

if oldRayCast then
    local function newRayCast(origin, direction, distance, ignore)
        if SilentAimEnabled then
            local closest = nil
            local shortest = SilentAimFOV
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("Head") then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(plr.Character.Head.Position)
                    if onScreen then
                        local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if dist < shortest then
                            shortest = dist
                            closest = plr.Character.Head
                        end
                    end
                end
            end
            if closest then
                direction = (closest.Position - origin).Unit
            end
        end

        local hitPosition = origin + direction.Unit * distance

        if TracersEnabled then
            local tracer = Instance.new("Part")
            tracer.Anchored = true
            tracer.CanCollide = false
            tracer.Transparency = TracerTransparency
            tracer.Color = TracerColor
            tracer.Material = Enum.Material.Neon
            tracer.Size = Vector3.new(TracerThickness, TracerThickness, (hitPosition - origin).Magnitude)
            tracer.CFrame = CFrame.new(origin, hitPosition) * CFrame.new(0, 0, -tracer.Size.Z/2)
            tracer.Parent = workspace
            game.Debris:AddItem(tracer, TracerDuration)
        end

        local ignoreList = ignore or {}
        if WallbangEnabled then
            table.insert(ignoreList, workspace)
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Character then table.insert(ignoreList, plr.Character) end
            end
        end

        if NoSpreadEnabled or SilentAimEnabled then
            local fakeHit = Instance.new("Part")
            fakeHit.Transparency = 1
            fakeHit.CanCollide = false
            fakeHit.Anchored = true
            fakeHit.Position = hitPosition
            return fakeHit, hitPosition
        end

        return oldRayCast(origin, direction, distance, ignoreList)
    end
    hookfunction(oldRayCast, newRayCast)
end


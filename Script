local function removeGarbageCooldown()
    for _, prompt in ipairs(workspace:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") and 
           (prompt.Name:lower():find("search") or prompt.Name:lower():find("bin") or 
            prompt.Name:lower():find("garbage") or prompt.Name:lower():find("trash")) then

local function findFireFunction()
    for _, v in pairs(getgc(true)) do
        if type(v) == "function" then
            local info = debug.getinfo(v)
            if info.source:find("GunScript") and info.name:find("Fire") then
                local function newFire(...)
                    local args = {...}
                    if NoSpreadEnabled and args[1] and type(args[1]) == "table" then
                        args[1].Spread = 0
                        args[1].CurrentSpread = 0
                    end
                    return v(unpack(args))
                end
                hookfunction(v, newFire)
                break
            end
        end
    end
end

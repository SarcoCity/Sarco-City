-- ==================== CLEAN VISUALS (Chams + Box only) ====================
local visuals = {}
local ChamsEnabled = false
local BoxESPEnabled = false
local ChamsFillTransparency = 0.5

local EnemyChamsColor = Color3.fromRGB(255, 0, 0)
local TeamChamsColor = Color3.fromRGB(0, 255, 0)
local EnemyBoxColor = Color3.fromRGB(255, 0, 0)

local function clearVisuals(player)
	if visuals[player] then
		for _, v in pairs(visuals[player]) do
			if v and v.Parent then v:Destroy() end
		end
		visuals[player] = nil
	end
end

local function updateVisualsForPlayer(player)
	clearVisuals(player)

	local char = player.Character
	if not char or not char:FindFirstChild("HumanoidRootPart") then return end

	visuals[player] = {}

	if ChamsEnabled or BoxESPEnabled then
		local highlight = Instance.new("Highlight")
		highlight.Adornee = char
		highlight.FillTransparency = ChamsEnabled and ChamsFillTransparency or 1
		highlight.OutlineTransparency = BoxESPEnabled and 0 or 1
		highlight.FillColor = (player.Team == LocalPlayer.Team) and TeamChamsColor or EnemyChamsColor
		highlight.OutlineColor = (player.Team == LocalPlayer.Team) and TeamChamsColor or EnemyBoxColor
		highlight.Parent = char
		table.insert(visuals[player], highlight)
	end
end

local function setupVisuals()
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			updateVisualsForPlayer(player)
		end
	end

	Players.PlayerAdded:Connect(function(player)
		if player == LocalPlayer then return end
		player.CharacterAdded:Connect(function()
			task.wait(0.5)
			updateVisualsForPlayer(player)
		end)
		player.CharacterRemoving:Connect(function()
			clearVisuals(player)
		end)
	end)
end

-- ==================== AIMBOT WITH KEYBINDS ====================
local AimbotEnabled = false
local AimbotFOV = 100
local AimbotSmoothness = 0.5
local AimbotTargetPart = "Head"
local AimbotKey = Enum.UserInputType.MouseButton2   -- Right Mouse Button by default

local aiming = false

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	if input.UserInputType == AimbotKey then
		aiming = true
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == AimbotKey then
		aiming = false
	end
end)

local function getClosestTarget()
	local closest = nil
	local shortestDistance = AimbotFOV

	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(AimbotTargetPart) then
			local targetPart = player.Character[AimbotTargetPart]
			local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
			if onScreen then
				local distance = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
				if distance < shortestDistance then
					shortestDistance = distance
					closest = targetPart
				end
			end
		end
	end
	return closest
end

RunService.RenderStepped:Connect(function()
	if not AimbotEnabled or not aiming then return end

	local target = getClosestTarget()
	if target then
		local targetPos = Camera:WorldToScreenPoint(target.Position)
		local currentMouse = UserInputService:GetMouseLocation()
		local smoothX = currentMouse.X + (targetPos.X - currentMouse.X) * AimbotSmoothness
		local smoothY = currentMouse.Y + (targetPos.Y - currentMouse.Y) * AimbotSmoothness
		mousemoverel(smoothX - currentMouse.X, smoothY - currentMouse.Y)
	end
end)

